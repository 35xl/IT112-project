import json

FILENAME = "inventory.json"

# Load inventory from file
def load_inventory():
    try:
        with open(FILENAME, "r") as file:
            return json.load(file)
    except FileNotFoundError:
        return {}

# Save inventory to file
def save_inventory(inventory):
    with open(FILENAME, "w") as file:
        json.dump(inventory, file)

# Add product
def add_product(inventory):
    name = input("Enter product name: ")
    price = float(input("Enter price: "))
    quantity = int(input("Enter quantity: "))

    inventory[name] = {"price": price, "quantity": quantity}
    save_inventory(inventory)
    print("Product added successfully!\n")

# View inventory
def view_inventory(inventory):
    if not inventory:
        print("Inventory is empty.\n")
        return

    print("\n--- Inventory ---")
    for name, details in inventory.items():
        print(f"{name} - Price: {details['price']} | Stock: {details['quantity']}")
    print()

# POS system (selling items)
def sell_product(inventory):
    name = input("Enter product name to sell: ")

    if name not in inventory:
        print("Product not found.\n")
        return

    quantity = int(input("Enter quantity to sell: "))

    if quantity > inventory[name]["quantity"]:
        print("Not enough stock.\n")
        return

    total = quantity * inventory[name]["price"]
    inventory[name]["quantity"] -= quantity

    save_inventory(inventory)

    print(f"Total price: {total}")
    print("Sale completed!\n")

# Main menu
def main():
    inventory = load_inventory()

    while True:
        print("==== Inventory POS System ====")
        print("1. Add Product")
        print("2. View Inventory")
        print("3. Sell Product")
        print("4. Exit")

        choice = input("Enter choice: ")

        if choice == "1":
            add_product(inventory)
        elif choice == "2":
            view_inventory(inventory)
        elif choice == "3":
            sell_product(inventory)
        elif choice == "4":
            print("Exiting system...")
            break
        else:
            print("Invalid choice.\n")

if __name__ == "__main__":
    main()
